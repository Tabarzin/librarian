    {
      "parameters": {
        "jsCode": "\n\n\n\nconst items = $input.all();\nreturn items.map(item => {\n let text = item.json.response || item.json.text || \"\";\n\n  // ... ваш код очистки HTML ...\n\nconst MAX_LENGTH = 3800; // Telegram лимит 4096, оставляем запас\n\nif (text.length > MAX_LENGTH) {\n    // Обрезаем аккуратно по последней точке перед лимитом, чтобы не рвать фразу\n    let trimmed = text.substring(0, MAX_LENGTH);\n    let lastDot = trimmed.lastIndexOf(\".\");\n    \n    if (lastDot > MAX_LENGTH - 500) { // Если точка нашлась недалеко от конца\n        text = trimmed.substring(0, lastDot + 1);\n    } else {\n        text = trimmed; // Если точек нет, режем жестко\n    }\n    \n    text += \"\\n\\n<i>(Ответ был сокращен из-за ограничений Telegram. Попробуйте уточнить вопрос.)</i>\";\n}\n\n\n  // 1. Экранируем существующие HTML символы, чтобы не сломать разметку\n  text = text\n    .replace(/&/g, \"&amp;\")\n    .replace(/</g, \"&lt;\")\n    .replace(/>/g, \"&gt;\");\n\n  // 2. Жирный текст: **text** -> <b>text</b>\n  text = text.replace(/\\*\\*(.*?)\\*\\*/g, '<b>$1</b>');\n  text = text.replace(/__(.*?)__/g, '<b>$1</b>');\n\n  // 3. Код: `text` -> <code>text</code>\n  text = text.replace(/`(.*?)`/g, '<code>$1</code>');\n\n  // 4. Блоки кода: ```text``` -> <pre>text</pre>\n  text = text.replace(/```([\\s\\S]*?)```/g, '<pre>$1</pre>');\n\n  // 5. САМОЕ ГЛАВНОЕ: Списки\n  // Заменяем \"* текст\" или \"- текст\" в начале строки на \"• текст\"\n  // Telegram не умеет делать HTML-списки, поэтому делаем их визуально.\n  \n  // Регулярка ищет: (начало строки или перенос)(пробелы)(звездочка или минус)(пробел)\n  text = text.replace(/(^|\\n)\\s*[\\*\\-]\\s+/g, '$1• ');\n\n  // 6. Заголовки Markdown (### Заголовок) -> Жирный текст\n  text = text.replace(/(^|\\n)\\s*#{1,6}\\s+(.*?)(?=\\n|$)/g, '$1<b>$2</b>');\n\n  item.json.response = text;\n  return item;\n});\n"
      },
